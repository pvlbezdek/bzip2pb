{
  "version": 3,
  "configurePresets": [
    {
      "name": "vcpkg-base",
      "hidden": true,
      "binaryDir": "${sourceDir}/build",
      "toolchainFile": "$env{VCPKG_INSTALLATION_ROOT}/scripts/buildsystems/vcpkg.cmake"
    },
    {
      "name": "windows-release",
      "displayName": "Windows x64 Release (MSVC + vcpkg)",
      "description": "Set VCPKG_INSTALLATION_ROOT to your vcpkg root, e.g. C:/Program Files/Microsoft Visual Studio/18/Community/VC/vcpkg",
      "inherits": "vcpkg-base",
      "generator": "Visual Studio 18 2026",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "VCPKG_TARGET_TRIPLET": "x64-windows"
      }
    },
    {
      "name": "windows-debug",
      "displayName": "Windows x64 Debug (MSVC + vcpkg)",
      "inherits": "windows-release",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      }
    },
    {
      "name": "ci-windows-latest-x64",
      "displayName": "CI: Windows x64 (VS 2022)",
      "inherits": "vcpkg-base",
      "generator": "Visual Studio 17 2022",
      "cacheVariables": {
        "VCPKG_TARGET_TRIPLET": "x64-windows"
      }
    },
    {
      "name": "ci-windows-latest-ARM64",
      "displayName": "CI: Windows ARM64 cross-compile (VS 2022)",
      "inherits": "vcpkg-base",
      "generator": "Visual Studio 17 2022",
      "architecture": {
        "value": "ARM64",
        "strategy": "set"
      },
      "cacheVariables": {
        "VCPKG_TARGET_TRIPLET": "arm64-windows"
      }
    },
    {
      "name": "ci-ubuntu-latest-x64",
      "displayName": "CI: Linux x64",
      "inherits": "vcpkg-base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "VCPKG_TARGET_TRIPLET": "x64-linux"
      }
    },
    {
      "name": "ci-macos-latest-arm64",
      "displayName": "CI: macOS ARM64",
      "inherits": "vcpkg-base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "VCPKG_TARGET_TRIPLET": "arm64-osx"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "release",
      "configurePreset": "windows-release",
      "configuration": "Release"
    },
    {
      "name": "debug",
      "configurePreset": "windows-debug",
      "configuration": "Debug"
    }
  ]
}
